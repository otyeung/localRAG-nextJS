OPENAI_API_KEY=replace-with-openai-api-key-or-local-placeholder
OPENAI_API_URL=http://localhost:11434
OPENAI_MODEL=llama3.2
OPENAI_EMBEDDING_MODEL=nomic-embed-text
DATABASE_URL=postgresql://app:app_password@postgres:5432/localrag_nextjs?schema=app
N8N_BASE_URL=http://n8n:5678
# Optional for local startup: leave blank for webhook-only mode unless an administrator provisions a real n8n API key outside this stack.
N8N_API_KEY=replace-with-admin-provisioned-n8n-api-key-or-leave-empty
N8N_WEBHOOK_SECRET=change-me-n8n-webhook-secret
LOCALRAG_APP_URL=http://nextjs:3000
N8N_TIMEOUT=30000
N8N_RETRY_COUNT=3
N8N_RETRY_DELAY=500
LOG_LEVEL=info
MAX_UPLOAD_SIZE=52428800
TEMP_UPLOAD_DIRECTORY=/tmp/localrag-nextjs/uploads
QDRANT_URL=http://qdrant:6333
QDRANT_COLLECTION=documents
QDRANT_VECTOR_SIZE=768
QDRANT_DISTANCE=Cosine
ANONYMOUS_COOKIE_SECRET=change-me-anonymous-cookie-secret
POSTGRES_USER=app
POSTGRES_PASSWORD=app_password
POSTGRES_DB=localrag_nextjs
N8N_ENCRYPTION_KEY=change-me-32-character-dev-key
N8N_USER_MANAGEMENT_JWT_SECRET=change-me-n8n-jwt-secret
REDIS_URL=redis://redis:6379
